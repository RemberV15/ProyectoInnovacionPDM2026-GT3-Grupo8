<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#F2F2F2">

    <ImageView
        android:id="@+id/iv_pin_logo"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/centinela1"
        android:contentDescription="Logo de la aplicación"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tv_pin_titulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Crear PIN de Acceso"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#050FA3"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tv_pin_subtitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ingresa un PIN de 4 dígitos para desbloquear la app rápidamente"
        android:textSize="14sp"
        android:textColor="#49454F"
        android:gravity="center"
        android:layout_marginBottom="32dp"/>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        app:boxStrokeColor="#050FA3"
        app:hintTextColor="#050FA3"
        android:layout_marginBottom="32dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_pin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberPassword"
            android:maxLength="4"
            android:gravity="center"
            android:textSize="24sp"
            android:textStyle="bold"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_continuar_pin"
        android:layout_width="200dp"
        android:layout_height="56dp"
        android:text="Continuar"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        app:backgroundTint="#050FA3"
        app:cornerRadius="28dp"/>

</LinearLayout>