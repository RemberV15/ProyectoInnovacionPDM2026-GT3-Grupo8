<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_redondeado"> <TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Filtrar por stock:"
    android:textSize="18sp"
    android:textStyle="bold"
    android:layout_marginBottom="20dp"
    android:textColor="#000000"
    android:gravity="center_horizontal"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:weightSum="3"
        android:gravity="center">

        <Button
            android:id="@+id/btn_cat"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Categoría"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_pill_button"
            android:textAllCaps="false"
            android:textSize="11sp"/>

        <Button
            android:id="@+id/btn_ubi"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Ubicación"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_pill_button"
            android:textAllCaps="false"
            android:textSize="11sp"/>

        <Button
            android:id="@+id/btn_est"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Estado"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_pill_button"
            android:textAllCaps="false"
            android:textSize="11sp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btn_limpiar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:text="Limpiar filtros"
        android:textColor="#050FA3"
        android:backgroundTint="#E8EAF6"
        android:textAllCaps="false"
        android:textSize="14sp"
        android:textStyle="bold"/>
</LinearLayout>