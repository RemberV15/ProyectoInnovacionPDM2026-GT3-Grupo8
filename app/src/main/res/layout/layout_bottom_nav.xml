<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:background="@drawable/bg_nav_rounded"
    android:elevation="12dp"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <LinearLayout android:id="@+id/nav_stock" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
        <ImageView android:id="@+id/iv_stock" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/package_2" app:tint="#757575" />
        <TextView android:id="@+id/tv_stock" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Stock" android:textColor="#757575" android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout android:id="@+id/nav_inicio" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
        <ImageView android:id="@+id/iv_inicio" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/home" app:tint="#757575" />
        <TextView android:id="@+id/tv_inicio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Inicio" android:textColor="#757575" android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout android:id="@+id/nav_escanear" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
        <ImageView android:id="@+id/iv_escanear" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/barcode_scanner" app:tint="#757575" />
        <TextView android:id="@+id/tv_escanear" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Escanear" android:textColor="#757575" android:textSize="10sp" />
    </LinearLayout>
</LinearLayout>